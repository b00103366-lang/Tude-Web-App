# ── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on.
# Railway sets this automatically; set it manually for local dev.
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Railway PostgreSQL plugin sets this automatically as DATABASE_URL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to HMAC-sign authentication tokens.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
TOKEN_SECRET=replace_with_a_random_64_char_hex_string_here_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: https://etude-plus.up.railway.app,https://etude-plus.vercel.app
CORS_ORIGINS=https://your-frontend-domain.com

# ── AI (optional) ────────────────────────────────────────────────────────────
# Anthropic API key for the in-class AI assistant.
# If not set, AI endpoints return 503 gracefully.
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud Storage (optional) ──────────────────────────────────────────
# Required only if professor document upload uses GCS.
# Leave blank to skip GCS initialisation.
GCS_BUCKET_NAME=your-bucket-name
# Path to a GCP service account JSON key file, OR use GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
