# ── API ──────────────────────────────────────────────────────────────────────
# Full URL of the deployed API server (no trailing slash).
# Used by the generated API client to construct request URLs.
VITE_API_BASE_URL=https://your-api-server.up.railway.app

# ── Vite build settings ───────────────────────────────────────────────────────
# Base path for assets and the Wouter router.
# Use "/" for root-domain deployments (Railway, Vercel).
# Use "/subpath/" only if the app is served from a subpath.
BASE_PATH=/

# PORT is only needed for the local dev/preview server, not for production builds.
# Railway injects PORT automatically when running `vite preview`.
# PORT=5173
