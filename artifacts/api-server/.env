PORT=3001
DATABASE_URL=postgresql://rayanbahloul@localhost:5432/etude_dev
TOKEN_SECRET=dev_secret_key_32chars_minimum_ok_here
CORS_ORIGINS=http://localhost:5173
NODE_ENV=development
# Required for AI features (Student AI tab). Get from console.anthropic.com
ANTHROPIC_API_KEY=

# Email (SMTP) — for verification codes. Leave empty to print codes to console (dev mode).
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Jitsi as a Service (JaaS) — free tier at https://jaas.8x8.vc
# Sign up → create an app → copy App ID + API Key ID + download private key PEM
# Paste the PEM private key on one line with literal \n between lines
JAAS_APP_ID=
JAAS_API_KEY_ID=
JAAS_PRIVATE_KEY=
